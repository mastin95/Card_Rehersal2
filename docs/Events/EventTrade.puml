@startuml
class EventTrade {
    + spend_gold : int
    + hp_damage : int
    + gain_gold : int
    + gain_xp : int
    + hp_heal : int
    + text : string
    + <<override>> AreEventsConditionMet(world:World, triggerer:Champion) : bool
    + <<override>> DoEvent(logic:WorldLogic, triggerer:Champion) : void
    + CanSpend(world:World, champion:Champion) : bool
    + Trade(logic:WorldLogic, champion:Champion) : void
}
EventData <|-- EventTrade
EventTrade --> "target" EventTarget
EventTrade --> "chain_event" EventData
@enduml
