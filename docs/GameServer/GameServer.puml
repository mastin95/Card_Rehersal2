    + ReceiveCreateChampion(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveDeleteChampion(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveStartGame(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveStartTest(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMapMove(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveCompleteAction(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveCompleteActionChampion(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveChangeState(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMapRewardCard(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMapRewardItem(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMapChoice(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMapUpgrade(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveLevelUp(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveTrashCard(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveBuyItem(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveBuyCard(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSellItem(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveUseItem(iclient:ClientData, sdata:SerializedData) : void
    + ReceivePlayCard(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveMoveCharacter(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveCastCardAbility(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSelectCard(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSelectCharacter(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSelectSlot(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSelectChoice(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveSelectCost(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveCancelSelection(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveEndTurn(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveResign(iclient:ClientData, sdata:SerializedData) : void
    + ReceiveChat(iclient:ClientData, sdata:SerializedData) : void
    + <<virtual>> SetWorld(world:World) : void
    + <<virtual>> StartScenario(world:World) : void
    + AddClient(client:ClientData) : void
    + RemoveClient(client:ClientData) : void
    + GetClient(client_id:ulong) : ClientData
    + AddPlayer(client:ClientData) : int
    + AfterPlayerConnected(player_id:int) : void
    + GetPlayer(client:ClientData) : Player
    + GetPlayer(user_id:string) : Player
    + IsPlayer(user_id:string) : bool
    + IsConnectedPlayer(user_id:string) : bool
    + CountPlayers() : int
