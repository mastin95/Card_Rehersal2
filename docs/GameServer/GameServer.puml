    + CountConnectedPlayers() : int
    + GetWorldData() : World
    + GetBattleData() : Battle
    + <<virtual>> HasStarted() : bool
    + <<virtual>> HasEnded() : bool
    + <<virtual>> IsExpired() : bool
    + <<virtual>> RefreshWorld() : void
    + <<virtual>> RefreshBattle() : void
    + SendToAll(tag:ushort) : void
    + SendToAll(tag:ushort, data:INetworkSerializable, delivery:NetworkDelivery) : void
    + ServerID : ulong <<get>>
}
struct QueuedGameAction {
    + type : ushort
}
GameServer --> "Messaging" NetworkMessaging
QueuedGameAction --> "client" ClientData
QueuedGameAction --> "sdata" SerializedData
@enduml
