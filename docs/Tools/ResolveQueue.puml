AttackQueueElement --> "callback<Card,Card,bool>" "Action`3"
AttackQueueElement --> "pcallback<Card,Player,bool>" "Action`3"
SecretQueueElement --> "secret_trigger" AbilityTrigger
SecretQueueElement --> "secret" Card
SecretQueueElement --> "triggerer" Card
SecretQueueElement --> "callback<AbilityTrigger,Card,Card>" "Action`3"
